# ---------------------------------------------------------------------------
# LiteLLM / Local vLLM Auto Profile (optional)
# ---------------------------------------------------------------------------
# Enable one-switch model profile:
# - default_model -> vllm-local/${VLLM_CHAT_MODEL}
# - fast_model    -> vllm-local/${VLLM_CHAT_MODEL}
# - embed_model   -> vllm/Qwen/Qwen3-Embedding-0.6B
# - reranker      -> vllm/BAAI/bge-reranker-v2-m3
# - enable_reranker=true
# YUXI_AUTO_USE_LITELLM=true
#
# Note:
# If any of VLLM_CHAT_BASE_URL / VLLM_EMBED_BASE_URL / VLLM_RERANK_BASE_URL
# is present, Yuxi-Know will auto-switch to the LiteLLM/vLLM profile by default.
# You can still force-disable with:
# YUXI_AUTO_USE_LITELLM=false
#
# If your LiteLLM runs on host machine (outside docker), keep localhost.
# In docker mode this project automatically maps localhost -> host.docker.internal.
# VLLM_CHAT_BASE_URL=http://localhost:4000/v1
# VLLM_EMBED_BASE_URL=http://localhost:4000/v1/embeddings
# VLLM_RERANK_BASE_URL=http://localhost:4000/v1/rerank
#
# Served model names in your LiteLLM config:
# VLLM_CHAT_MODEL=Qwen3.5-35B-A3B-FP8
# VLLM_EMBED_MODEL=Qwen3-Embedding-0.6B
# VLLM_RERANK_MODEL=qwen3-rerank
#
# Optional explicit overrides (higher priority than auto profile):
# YUXI_DEFAULT_MODEL=vllm-local/Qwen3.5-35B-A3B-FP8
# YUXI_FAST_MODEL=vllm-local/Qwen3.5-35B-A3B-FP8
# YUXI_EMBED_MODEL=vllm/Qwen/Qwen3-Embedding-0.6B
# YUXI_RERANKER_MODEL=vllm/BAAI/bge-reranker-v2-m3
# YUXI_ENABLE_RERANKER=true

# # MinerU
# MINERU_API_KEY=

